	cd /home/kviolet/workspace/tinytoolkit/softwore/build_linux && $(MAKE) $(MAKESILENT) -f project/svo_viwer/CMakeFiles/svo_viewer.dir/build.make project/svo_viwer/CMakeFiles/svo_viewer.dir/toolkit/utilities/net.cpp.i
.PHONY : toolkit/utilities/net.cpp.i

toolkit/utilities/net.s: toolkit/utilities/net.cpp.s
.PHONY : toolkit/utilities/net.s

# target to generate assembly for a file
toolkit/utilities/net.cpp.s:
	cd /home/kviolet/workspace/tinytoolkit/softwore/build_linux && $(MAKE) $(MAKESILENT) -f project/svo_viwer/CMakeFiles/svo_viewer.dir/build.make project/svo_viwer/CMakeFiles/svo_viewer.dir/toolkit/utilities/net.cpp.s
.PHONY : toolkit/utilities/net.cpp.s

